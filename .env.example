# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
# Optional: choose a model supported by the Responses API (e.g., gpt-5.2, gpt-5, gpt-4o, etc.)
OPENAI_MODEL=gpt-5.2

# Public site URL for sitemap/metadata (set this in production)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Optional: comma-separated allowlist domains for the companion bot.
# If set, it will ONLY accept citations from these hostnames (plus .gov/.edu/.org/.ac.uk by default).
# Example: pewresearch.org,cpsc.gov,ftc.gov,openai.com,yaqeeninstitute.org
CHAT_EXTRA_ALLOWED_DOMAINS=
